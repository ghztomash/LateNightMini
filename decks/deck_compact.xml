<Template>
  <WidgetGroup>
    <Layout>horizontal</Layout>
    <SizePolicy>me,min</SizePolicy>
    <Children>

      <WidgetGroup>
        <ObjectName>DeckCompact<Variable name="ChanNum" /></ObjectName>
        <Layout>horizontal</Layout>
        <SizePolicy>me,min</SizePolicy>
        <Children>

          <WidgetGroup>
            <ObjectName>DeckRows2345</ObjectName>
            <SizePolicy>me,min</SizePolicy>
            <Layout>vertical</Layout>
            <Children>
              <WidgetGroup>
                <ObjectName>DeckRows234</ObjectName>
                <SizePolicy>me,min</SizePolicy>
                <Layout>horizontal</Layout>
                <Children>

                  <WidgetGroup>
                    <SizePolicy>me,min</SizePolicy>
                    <Layout>vertical</Layout>
                    <Children>
                      <Template src="skin:../LateNightMini/decks/row_2_3_TitleArtistTime_compact.xml" />
                      <Template src="skin:../LateNightMini/decks/row_4_overviewSpinny_compact.xml" />
                    </Children>
                  </WidgetGroup>

                  <WidgetGroup>
                    <Size>1f,0min</Size>
                    <Connection>
                      <ConfigKey persist="true">[Skin],show_rate_controls_compact</ConfigKey>
                      <Transform><Not/></Transform>
                      <BindProperty>visible</BindProperty>
                    </Connection>
                  </WidgetGroup>

                </Children>
              </WidgetGroup><!-- DeckRows234 -->

              <Template src="skin:../LateNightMini/decks/row_5_transportLoopJump_compact.xml" />

            </Children>
          </WidgetGroup><!-- DeckRows2345 -->

          <WidgetGroup>
            <SizePolicy>min,min</SizePolicy>
            <Layout>horizontal</Layout>
            <Children>
              <WidgetGroup>
                <ObjectName>DeckRateSpacer</ObjectName>
                <SizePolicy>min,min</SizePolicy>
                <Children/>
                <Connection>
                  <ConfigKey persist="true">[LateNightMini],show_vumeters_compact</ConfigKey>
                  <Transform><Not/></Transform>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </WidgetGroup>
            </Children>
            <Connection>
              <ConfigKey persist="true">[Skin],show_rate_controls_compact</ConfigKey>
              <Transform><Not/></Transform>
              <BindProperty>visible</BindProperty>
            </Connection>
          </WidgetGroup>

          <Template src="skin:../LateNightMini/decks/rate_controls_compact.xml"/>

        </Children>
      </WidgetGroup><!-- DeckCompactN -->

    </Children>
  </WidgetGroup>
</Template>
